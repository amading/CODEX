# ════════════════════════════════════════════════════════════════════════════
# Pack intelligence (photo → product hints)
# ════════════════════════════════════════════════════════════════════════════

# Resale / production: YOUR server hosts Gemini (recommended). SPA calls this URL; keys stay off the client.
# Run: cd server && npm install && npm start — see server/.env.example for GEMINI_API_KEY.
# VITE_PRODUCT_IDENTIFY_URL=http://127.0.0.1:8787

# Optional, only if IDENTIFY_API_SECRET is set on the server
# VITE_PRODUCT_IDENTIFY_SECRET=

# Shared product catalog (PHP in htdocs) — lookup by barcode across all stores; Save Product upserts.
# Example: http://localhost/suklihub-bir/api/products_catalog.php
# VITE_PRODUCTS_CATALOG_URL=

# Optional: per-store inventory API (replace-all JSON). Example: http://localhost/suklihub-bir/api/inventory_products.php
# VITE_INVENTORY_PRODUCTS_URL=

# Real vision — optional key from https://aistudio.google.com/apikey
# If set, Gemini reads the packaging photo.
# WARNING: Vite inlines VITE_* into the browser; use a backend proxy in production.
# VITE_GEMINI_API_KEY=

# Optional Google programmable search (server-side only) for extra web hints:
# GOOGLE_CSE_API_KEY=
# GOOGLE_CSE_CX=

# Optional if your account does not have 2.0 Flash yet:
# VITE_GEMINI_MODEL=gemini-1.5-flash
